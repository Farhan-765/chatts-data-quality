   "source": [
    "# Ablation 2 — Pre-Screener Threshold Sensitivity\n",
    "\n",
    "**Thesis Section**: Sensitivity of Approach 3 to statistical pre-screener thresholds.\n",
    "\n",
    "Tests the effect of changing three key thresholds:\n",
    "1. `sigma_threshold` (spike detection): 3.0 / 4.0 / 5.0\n",
    "2. `drift_ratio_threshold`: 0.10 / 0.15 / 0.20\n",
    "3. `std_threshold` (frozen): 0.005 / 0.010 / 0.020\n",
    "\n",
    "Final (locked) values are from `configs/prescreener.yaml`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../..')\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv('../../.env')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from src.data.timeseer_client import fetch_series_api, list_series_api\n",
    "from src.data.ground_truth import GROUND_TRUTH\n",
    "\n",
    "print('Imports OK')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_prescreener(\n",
    "    vals, tag,\n",
    "    sigma_threshold=4.0,\n",
    "    drift_ratio_threshold=0.15,\n",
    "    std_threshold=0.01,\n",
    "    seasonality_filter=0.3,\n",
    "):\n",
    "    \"\"\"Parameterized pre-screener — same logic as hybrid_analyze but with configurable thresholds.\"\"\"\n",
    "    n = len(vals)\n",
    "    series = pd.Series(vals)\n",
    "    global_mean = float(vals.mean())\n",
    "    global_std  = float(vals.std())\n",
    "    signal_range = float(vals.max() - vals.min())\n",
    "\n",
    "    # Frozen\n",
    "    roll_std = series.rolling(10).std().fillna(1.0)\n",
    "    frozen = roll_std.min() < std_threshold and (np.diff(vals) == 0).sum() > 10\n",
    "\n",
    "    # Drift\n",
    "    roll_mean = series.rolling(96).mean().dropna()\n",
    "    roll_mean_range = float(roll_mean.max() - roll_mean.min()) if len(roll_mean) > 0 else 0\n",
    "    drift_ratio = roll_mean_range / signal_range if signal_range > 0 else 0\n",
    "    roll_mean_std = float(roll_mean.std()) if len(roll_mean) > 0 else 0\n",
    "    drift = drift_ratio > drift_ratio_threshold and roll_mean_std > seasonality_filter * global_std\n",
    "\n",
    "    # Spikes — using shift(5) pre-spike baseline\n",
    "    roll_mean_pre = series.rolling(10).mean().shift(5).fillna(global_mean)\n",
    "    roll_std_pre  = series.rolling(10).std().shift(5).fillna(global_std)\n",
    "    local_dev     = np.abs(vals - roll_mean_pre.values)\n",
    "    spike_mask    = local_dev > sigma_threshold * roll_std_pre.values\n",
    "    n_spikes = spike_mask.sum()\n",
    "    spikes = n_spikes >= 1 and (local_dev[spike_mask].max() > 0.20 * signal_range if spike_mask.any() else False)\n",
    "\n",
    "    detected = []\n",
    "    if frozen: detected.append('stale')\n",
    "    if drift:  detected.append('drift')\n",
    "    if spikes: detected.append('spikes')\n",
    "    if not detected: detected.append('clean')\n",
    "\n",
    "    # Map to category\n",
    "    if 'stale' in detected: return 'C'\n",
    "    if 'drift' in detected and 'spikes' not in detected: return 'A'\n",
    "    if 'spikes' in detected: return 'B'\n",
    "    return 'E'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test on Reactor 1 (6 signals, known ground truth)\n",
    "AREA = 'Reactor 1'\n",
    "tags = list_series_api(AREA)\n",
    "\n",
    "signal_data = {}\n",
    "for tag in tags:\n",
    "    vals, _ = fetch_series_api(tag, AREA)\n",
    "    if vals is not None:\n",
    "        signal_data[tag] = vals\n",
    "\n",
    "SKIP = {'R1-AT-104-TEMP', 'R1-AT-105-PRESS', 'R1-AT-106-ORP'}  # daily-cycle signals\n",
    "\n",
    "print(f'\\n{\"Parameter\":<35} {\"Accuracy\":>10}  {\"Correct signals\"}')\n",
    "print('-' * 65)\n",
    "\n",
    "configs = [\n",
    "    ('sigma=3.0 (loose)',     dict(sigma_threshold=3.0)),\n",
    "    ('sigma=4.0 (final)',     dict(sigma_threshold=4.0)),\n",
    "    ('sigma=5.0 (strict)',    dict(sigma_threshold=5.0)),\n",
    "    ('drift_ratio=0.10',      dict(drift_ratio_threshold=0.10)),\n",
    "    ('drift_ratio=0.15 (final)', dict(drift_ratio_threshold=0.15)),\n",
    "    ('drift_ratio=0.20',      dict(drift_ratio_threshold=0.20)),\n",
    "    ('std_thr=0.005 (strict)',dict(std_threshold=0.005)),\n",
    "    ('std_thr=0.010 (final)', dict(std_threshold=0.010)),\n",
    "    ('std_thr=0.020 (loose)', dict(std_threshold=0.020)),\n",
    "]\n",
    "\n",
    "for name, kwargs in configs:\n",
    "    correct = 0\n",
    "    total   = 0\n",
    "    details = []\n",
    "    for tag, vals in signal_data.items():\n",
    "        if tag in SKIP: continue\n",
    "        gt = GROUND_TRUTH.get(tag, '?')\n",
    "        if gt == '?': continue\n",
    "        pred = run_prescreener(vals, tag, **kwargs)\n",
    "        match = (pred == gt or (pred == 'B' and gt == 'B+L'))\n",
    "        correct += int(match)\n",
    "        total   += 1\n",
    "        details.append(f'{tag}:{pred}({gt})')\n",
    "    acc = correct / total if total else 0\n",
    "    print(f'{name:<35} {acc*100:>8.1f}%  {correct}/{total}  {\"  \".join(details)}')"
   ]
  }
 ],

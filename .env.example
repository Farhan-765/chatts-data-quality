# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Timeseer API ─────────────────────────────────────────────────
# Base64-encoded "user:password" for Basic Auth
TIMESEER_API_TOKEN=your-base64-token-here
TIMESEER_BASE_URL=https://app.timeseer.ai
TIMESEER_TENANT=UHasselt
TIMESEER_DS_NAME=Industrial analyzers

# ── VSC paths (only needed when running on VSC) ──────────────────
# Override these in .env if your scratch path differs
VSC_SCRATCH=/scratch/leuven/375/vsc37531

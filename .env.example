# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# OpenAI
OPENAI_API_KEY=your-openai-key-here

# Timeseer API
# Base64-encoded "user:password" for Basic Auth
TIMESEER_API_TOKEN=your-base64-token-here
TIMESEER_BASE_URL=your-timeseer-instance-url
TIMESEER_TENANT=your-tenant-name
TIMESEER_DS_NAME=your-dataset-name

# VSC paths (only needed when running on VSC)
VSC_SCRATCH=/scratch/leuven/your-vsc-id
